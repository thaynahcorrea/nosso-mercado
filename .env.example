# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase.
# (Dashboard → Project Settings → API)
# A chave "anon public" PODE ficar no app — ela é feita para isso, protegida pelas
# regras de segurança (RLS). NUNCA use aqui a chave "service_role".
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public
